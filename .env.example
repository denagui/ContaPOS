# Variables de entorno para desarrollo local
# Copiar a .env y ajustar según necesidad

# Modo desarrollo
NODE_ENV=development

# URL de la API (desarrollo local)
PUBLIC_API_URL=http://localhost:5173

# Configuración de Cloudflare (simulado en local)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Base de datos D1 (wrangler.toml ya tiene la configuración)
# DATABASE_ID se obtiene con: wrangler d1 create pos-database

# KV Namespace (opcional para auth en local)
# KV_ID se obtiene con: wrangler kv:namespace create SESSION_KV
